# Resend API key — get one at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Verified sender. Must be a domain you verified in Resend.
# The sample email used: Tirbeo Support <noreply@send.tirbeo.app>
MAIL_FROM=Tirbeo Support <noreply@send.tirbeo.app>

# Secret used to sign the one-time code cookie. Use a long random string in prod.
CODE_SECRET=change-me-to-a-long-random-string
